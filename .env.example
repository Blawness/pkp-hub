# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/pkp_hub"

# Better Auth (required) — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="min-32-char-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# App URL (required, client-exposed)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudflare R2 storage (optional — falls back to local .storage/ driver)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Resend email (optional — falls back to console.log)
RESEND_API_KEY=""

# Set to "true" to skip env validation (e.g. during build without secrets)
SKIP_ENV_VALIDATION=""
